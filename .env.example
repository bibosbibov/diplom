# =============================================================================
# Шаблон переменных окружения
# Скопируйте этот файл в .env и заполните значения.
# Сам файл .env не должен попадать в git (см. .gitignore).
# =============================================================================

# --- API-ключи источников данных ---

# Ключ NVD API 2.0 (увеличивает rate limit с 5 до 50 запросов/30 сек).
# Получить: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# (опционально) Токен GitHub для скачивания ExploitDB через GitHub API
# (без него используется публичный raw-URL без аутентификации).
GITHUB_TOKEN=

# --- Логирование ---

# Уровень логирования для консоли: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Путь к лог-файлу (относительно корня проекта).
LOG_FILE=logs/app.log

# --- Конфигурация ---

# Путь к основному конфигу.
CONFIG_PATH=configs/config.yaml

# --- Веб-сервис (FastAPI) ---

API_HOST=0.0.0.0
API_PORT=8000

# --- Обучение ---

# Принудительный выбор устройства: cuda | cpu | auto
DEVICE=auto

# Каталог для кэша моделей Hugging Face (по умолчанию ~/.cache/huggingface).
HF_HOME=

# Отключить телеметрию transformers / datasets.
TRANSFORMERS_OFFLINE=0
HF_DATASETS_OFFLINE=0

# --- Воспроизводимость ---

# Глобальный seed (дублирует значение из config.yaml; имеет приоритет, если задан).
SEED=42
